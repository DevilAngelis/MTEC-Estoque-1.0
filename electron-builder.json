{
  "appId": "com.mtec.estoque",
  "productName": "MTec Estoque",
  "directories": {
    "output": "release"
  },
  "afterSign": null,
  "afterAllArtifactBuild": null,
  "files": [
    "build/**/*",
    "dist/**/*",
    "electron/**/*",
    "package.json",
    "node_modules/**/*",
    "!node_modules/.cache",
    "!node_modules/electron/**/*"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      }
    ],
    "icon": "assets/images/icon.ico",
    "publisherName": "MTec Energia",
    "sign": null,
    "signingHashAlgorithms": null,
    "verifyUpdateCodeSignature": false,
    "certificateFile": null,
    "certificatePassword": null
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "MTec Estoque",
    "installerIcon": "assets/images/icon.ico",
    "uninstallerIcon": "assets/images/icon.ico",
    "installerHeaderIcon": "assets/images/icon.ico",
    "deleteAppDataOnUninstall": false
  },
  "mac": {
    "target": "dmg",
    "icon": "assets/images/icon.icns",
    "category": "public.app-category.business"
  },
  "linux": {
    "target": "AppImage",
    "icon": "assets/images/icon.png",
    "category": "Office"
  }
}
